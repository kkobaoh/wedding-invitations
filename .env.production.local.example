# ==============================================================
# 本番環境用 環境変数
# ==============================================================
# ⚠️  通常、このファイルは使用しません。
#     Vercel へのデプロイ時は Vercel ダッシュボードで環境変数を管理します。
#
# 【Vercel での設定手順】
#   1. Vercel ダッシュボード > プロジェクト > Settings > Environment Variables
#   2. [Add] をクリック
#   3. Name: DATABASE_URL
#      Value: <本番用 Neon 接続文字列>
#      Environment: Production（必要に応じて Preview にも追加）
#   4. [Save] をクリックして再デプロイ
#
# 【ローカルで本番 DB に接続したい場合のみ使用】
#   このファイルを .env.production.local にコピーしてください。
#   next build / next start 実行時のみ読み込まれます。
#   .env.production.local は .gitignore で除外されています。
#
#   cp .env.production.local.example .env.production.local
#
# 【Neon での本番ブランチ確認手順】
#   1. Neon Console > プロジェクト > Branches > main
#   2. [Connection string] をコピーして DATABASE_URL に貼り付け
# ==============================================================

DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob（画像アップロード用）
# Vercel ダッシュボード > Storage > Blob で確認できます。
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx
