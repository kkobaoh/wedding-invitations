# ─────────────────────────────────────────────────────
# Docker ローカル環境用の接続設定
# このファイルを .env.docker にコピーして使用してください
# ─────────────────────────────────────────────────────

# docker-compose.yml の設定と一致させる
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding_invitations

# ─────────────────────────────────────────────────────
# npm run dev でローカル Docker に接続する場合は
# .env.local の DATABASE_URL を上記の値に変更してください
# ─────────────────────────────────────────────────────
