# ==============================================================
# 開発環境用 環境変数
# ==============================================================
# このファイルを .env.local にコピーして使用してください。
#   cp .env.local.example .env.local
#
# .env.local は .gitignore で除外されています。
# 実際の接続文字列を記入してもコミットされません。
#
# 【Neon での開発ブランチ作成手順】
#   1. Neon Console > プロジェクト > Branches
#   2. [Create Branch] をクリック
#   3. ブランチ名: dev（または任意）、From: main を選択
#   4. 作成後 [Connection string] をコピーして DATABASE_URL に貼り付け
# ==============================================================

DATABASE_URL=postgresql://user:password@ep-xxxx-dev.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob（画像アップロード用）
# Vercel ダッシュボード > Storage > Blob > Connect を実施後、
# 自動的に付与されるトークンをコピーして貼り付けてください。
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx
